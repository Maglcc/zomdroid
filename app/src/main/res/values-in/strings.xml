    <string name="install_mod_zip_help_title">Struktur arsip mod</string>

    <string name="install_mod_zip_help_message">
        \u2705 Correct examples:\n\n

        Single mod:\n
        ModName/\n
        \u00A0\u00A0mod.info\n
        \u00A0\u00A0media/\n
        \u00A0\u00A0scripts/\n\n

        Multiple mods in one ZIP:\n
        ModA/\n
        \u00A0\u00A0mod.info\n
        ModB/\n
        \u00A0\u00A0mod.info\n\n

        \u274C Incorrect examples:\n\n

        Extra wrapper folder:\n
        Downloads/\n
        \u00A0\u00A0ModName/\n
        \u00A0\u00A0\u00A0\u00A0mod.info\n\n

        Missing mod root:\n
        media/\n
        scripts/\n
        (no mod.info in root)
    </string>


